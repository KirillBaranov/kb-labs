{
  "name": "@kb-labs/monorepo",
  "description": "KB Labs — open-source AI/infra control plane for developers.",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "author": {
    "name": "Kirill Baranov",
    "url": "https://github.com/KirillBaranov"
  },
  "license": "MIT",
  "scripts": {
    "bootstrap": "./bootstrap.sh",
    "build": "./tools/kb-devkit/kb-devkit run build",
    "build:affected": "./tools/kb-devkit/kb-devkit run build --affected",
    "build:clean": "pnpm clean && pnpm build",
    "changeset": "changeset",
    "check": "./tools/kb-devkit/kb-devkit run build lint type-check test",
    "check:affected": "./tools/kb-devkit/kb-devkit run build lint type-check test --affected",
    "clean": "pnpm -r run clean",
    "clean:all": "pnpm -r run clean && rimraf node_modules",
    "deploy": "./tools/kb-deploy/kb-deploy run",
    "deploy:all": "./tools/kb-deploy/kb-deploy run --all",
    "deploy:status": "./tools/kb-deploy/kb-deploy status",
    "deps:check": "syncpack list-mismatches",
    "deps:fix": "syncpack fix-mismatches && syncpack format",
    "deps:format": "syncpack format",
    "deps:lint": "syncpack lint",
    "deps:list": "syncpack list",
    "dev:logs": "./tools/kb-dev/kb-dev logs",
    "dev:restart": "./tools/kb-dev/kb-dev restart",
    "dev:start": "./tools/kb-dev/kb-dev start",
    "dev:status": "./tools/kb-dev/kb-dev status",
    "dev:stop": "./tools/kb-dev/kb-dev stop",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "health": "./tools/kb-devkit/kb-devkit stats",
    "kb": "node ./cli/bin/dist/bin.js",
    "lint": "./tools/kb-devkit/kb-devkit run lint",
    "monitor": "./tools/kb-monitor/kb-monitor status",
    "monitor:health": "./tools/kb-monitor/kb-monitor health",
    "monitor:logs": "./tools/kb-monitor/kb-monitor logs",
    "release": "changeset publish",
    "release:platform": "chmod +x ./tools/kb-devkit/kb-devkit && ./tools/kb-devkit/kb-devkit run build && node ./cli/bin/dist/bin.js marketplace:clear-cache && node ./cli/bin/dist/bin.js release run --flow platform --skip-build --yes",
    "release:platform:dry": "chmod +x ./tools/kb-devkit/kb-devkit && ./tools/kb-devkit/kb-devkit run build && node ./cli/bin/dist/bin.js marketplace:clear-cache && node ./cli/bin/dist/bin.js release run --flow platform --skip-build --dry-run",
    "release:sdk": "chmod +x ./tools/kb-devkit/kb-devkit && ./tools/kb-devkit/kb-devkit run build && node ./cli/bin/dist/bin.js marketplace:clear-cache && node ./cli/bin/dist/bin.js release run --flow sdk --skip-build --yes",
    "release:sdk:dry": "chmod +x ./tools/kb-devkit/kb-devkit && ./tools/kb-devkit/kb-devkit run build && node ./cli/bin/dist/bin.js marketplace:clear-cache && node ./cli/bin/dist/bin.js release run --flow sdk --skip-build --dry-run",
    "test": "./tools/kb-devkit/kb-devkit run test",
    "type-check": "./tools/kb-devkit/kb-devkit run type-check",
    "version": "changeset version",
    "ws:check": "./tools/kb-devkit/kb-devkit check",
    "ws:fix": "./tools/kb-devkit/kb-devkit fix --safe"
  },
  "devDependencies": {
    "@kb-labs/devkit": "workspace:*",
    "@types/node": "^24.3.3",
    "@vitest/coverage-istanbul": "^4.1.4",
    "@vitest/coverage-v8": "^3",
    "eslint": "^9.39.1",
    "knip": "^6.4.0",
    "prettier": "^3",
    "rimraf": "^6",
    "syncpack": "^13.0.4",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.11.0",
  "pnpm": {
    "overrides": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "zod": "^3.25.76",
      "@fastify/reply-from": ">=12.6.2",
      "@fastify/static": ">=9.1.1",
      "follow-redirects": ">=1.16.0",
      "hono": ">=4.12.14",
      "koa": ">=2.16.4",
      "minimatch": ">=9.0.7"
    }
  },
  "repository": "KirillBaranov/kb-labs.git"
}
