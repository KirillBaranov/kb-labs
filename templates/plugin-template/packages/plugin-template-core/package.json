{
  "name": "@kb-labs/plugin-template-core",
  "description": "Reference plugin package for KB Labs plugin template with manifest, CLI, REST, and Studio layers.",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin-manifest": {
      "types": "./dist/manifest.v3.d.ts",
      "import": "./dist/manifest.v3.js"
    },
    "./plugin-manifest-v2": {
      "types": "./dist/manifest.v2.d.ts",
      "import": "./dist/manifest.v2.js"
    },
    "./cli": "./dist/cli/index.js",
    "./rest": "./dist/rest/index.js",
    "./studio": "./dist/studio/index.js",
    "./core": "./dist/core/index.js",
    "./utils": "./dist/utils/index.js",
    "./lifecycle": "./dist/lifecycle/index.js",
    "./studio/widgets/hello": {
      "types": "./dist/studio/widgets/hello-widget.d.ts",
      "import": "./dist/studio/widgets/hello-widget.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rimraf dist",
    "dev": "tsup --config tsup.config.ts --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint . --fix",
    "pretype-check": "pnpm --filter @kb-labs/plugin-template-core build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@kb-labs/plugin-contracts": "workspace:*",
    "@kb-labs/plugin-template-contracts": "workspace:*",
    "@kb-labs/sdk": "workspace:*",
    "react": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@kb-labs/devkit": "workspace:*",
    "@kb-labs/plugin-runtime": "workspace:*",
    "@types/node": "^24.3.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "kb": {
    "manifest": "./dist/manifest.v3.js"
  },
  "sideEffects": false
}
