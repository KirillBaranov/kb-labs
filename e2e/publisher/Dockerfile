# Publisher container — publishes all @kb-labs/*.tgz tarballs to Verdaccio.
# Runs once (CMD = publish.sh) and exits 0. Compose waits for it via
# condition: service_completed_successfully before starting platform.
#
# Build context: e2e/  (so COPY packages/ works)

FROM node:20-alpine

# pnpm is required for publishing — it writes sha512 integrity hashes that
# pnpm on the consuming side (platform container) can verify.
# npm publish writes sha1, which causes ERR_PNPM_TARBALL_INTEGRITY.
RUN apk add --no-cache curl python3 && \
    npm install -g pnpm@9 --quiet

RUN mkdir -p /packages

# Tarballs are baked into the image at build time (generated by pack-all.sh).
# Copy the whole directory so the glob doesn't fail when building locally
# without packing (publish.sh handles an empty /packages dir gracefully).
COPY packages/ /packages/

COPY publisher/publish.sh /publish.sh
RUN chmod +x /publish.sh

CMD ["/publish.sh"]
