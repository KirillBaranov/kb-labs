{
  "version": "3.0.0",
  "registryUrl": "http://verdaccio:4873",
  "core": [
    { "name": "@kb-labs/cli-bin" },
    { "name": "@kb-labs/devkit" },
    { "name": "@kb-labs/sdk" },
    { "name": "@kb-labs/core-runtime" },
    { "name": "@kb-labs/core-contracts" },
    { "name": "@kb-labs/shared-cli-ui" },
    { "name": "@kb-labs/core-state-daemon" },
    { "name": "@kb-labs/adapters-kblabs-gateway" }
  ],
  "services": [
    {
      "id": "rest",
      "pkg": "@kb-labs/rest-api-app",
      "description": "REST API (port 5050)",
      "default": true,
      "port": 5050,
      "gatewayPrefix": "/api/v1"
    },
    {
      "id": "workflow",
      "pkg": "@kb-labs/workflow-daemon",
      "description": "Workflow engine (port 7778)",
      "default": true,
      "port": 7778,
      "gatewayPrefix": "/api/exec",
      "gatewayRewrite": "",
      "plugin": "@kb-labs/workflow-entry"
    },
    {
      "id": "gateway",
      "pkg": "@kb-labs/gateway-app",
      "description": "Central router (port 4000)",
      "default": true,
      "port": 4000
    },
    {
      "id": "marketplace",
      "pkg": "@kb-labs/marketplace-app",
      "description": "Marketplace (port 5070)",
      "default": true,
      "port": 5070,
      "gatewayPrefix": "/api/v1/marketplace"
    },
    {
      "id": "studio",
      "pkg": "@kb-labs/studio-app",
      "description": "Web UI (port 3000)",
      "default": true,
      "port": 3000
    }
  ],
  "adapters": [
    { "name": "@kb-labs/adapters-fs" },
    { "name": "@kb-labs/adapters-pino" },
    { "name": "@kb-labs/adapters-log-ringbuffer" },
    { "name": "@kb-labs/adapters-analytics-file" }
  ],
  "plugins": [
    {
      "id": "marketplace",
      "pkg": "@kb-labs/marketplace-entry",
      "description": "Install, list, enable plugins",
      "default": true
    },
    {
      "id": "mind",
      "pkg": "@kb-labs/mind-entry",
      "description": "AI code search (RAG)",
      "default": false
    },
    {
      "id": "agents",
      "pkg": "@kb-labs/agent-entry",
      "description": "Autonomous agents",
      "default": false
    },
    {
      "id": "ai-review",
      "pkg": "@kb-labs/review-entry",
      "description": "AI code review",
      "default": true
    },
    {
      "id": "commit",
      "pkg": "@kb-labs/commit-entry",
      "description": "AI commit generation",
      "default": true
    },
    {
      "id": "scaffold",
      "pkg": "@kb-labs/scaffold",
      "description": "Scaffold plugins and adapters",
      "default": true
    },
    {
      "id": "release",
      "pkg": "@kb-labs/release-manager-cli",
      "description": "Release manager — plan, publish, workflow templates",
      "default": true
    }
  ],
  "binaries": [
    {
      "id": "kb-dev",
      "repo": "KirillBaranov/kb-labs",
      "name": "kb-dev",
      "description": "Service manager",
      "default": true,
      "localPath": "/usr/local/bin/kb-dev"
    },
    {
      "id": "kb-devkit",
      "repo": "KirillBaranov/kb-labs",
      "name": "kb-devkit",
      "description": "Workspace orchestrator",
      "default": false
    },
    {
      "id": "kb-deploy",
      "repo": "KirillBaranov/kb-labs",
      "name": "kb-deploy",
      "description": "Deployment manager",
      "default": false
    },
    {
      "id": "kb-monitor",
      "repo": "KirillBaranov/kb-labs",
      "name": "kb-monitor",
      "description": "Runtime monitor",
      "default": false
    }
  ]
}
