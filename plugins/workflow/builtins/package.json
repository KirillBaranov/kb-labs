{
  "name": "@kb-labs/workflow-builtins",
  "version": "2.11.0",
  "description": "Built-in workflow handlers (shell, etc.)",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shell": {
      "types": "./dist/shell.d.ts",
      "import": "./dist/shell.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm clean && tsup --config tsup.config.ts",
    "clean": "rimraf dist",
    "dev": "tsup --config tsup.config.ts --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kb-labs/plugin-contracts": "workspace:*",
    "execa": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "@kb-labs/devkit": "workspace:*",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
