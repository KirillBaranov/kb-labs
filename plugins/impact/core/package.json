{
  "name": "@kb-labs/impact-core",
  "version": "2.16.0",
  "type": "module",
  "description": "Core implementation of KB Labs Impact Analysis Plugin.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin-manifest": {
      "import": "./dist/manifest.v3.js",
      "types": "./dist/manifest.v3.d.ts"
    },
    "./cli": "./dist/cli/index.js",
    "./core": "./dist/core/index.js",
    "./dist/*": "./dist/*"
  },
  "kb": {
    "manifest": "./dist/manifest.v3.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "pretype-check": "pnpm --filter @kb-labs/impact-core build",
    "clean": "rimraf dist",
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kb-labs/impact-contracts": "workspace:*",
    "@kb-labs/sdk": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@kb-labs/devkit": "workspace:*",
    "@types/node": "^24.3.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
