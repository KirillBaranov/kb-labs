{
  "name": "@kb-labs/scaffold",
  "version": "2.30.0",
  "type": "module",
  "description": "Generic entity scaffolder for KB Labs plugins, adapters, and friends.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin-manifest": {
      "import": "./dist/manifest.js",
      "types": "./dist/manifest.d.ts"
    }
  },
  "kb": {
    "manifest": "./dist/manifest.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@kb-labs/scaffold-contracts": "workspace:*",
    "@kb-labs/scaffold-core": "workspace:*",
    "@kb-labs/sdk": "workspace:*",
    "@clack/prompts": "^0.11.0"
  },
  "devDependencies": {
    "@kb-labs/devkit": "workspace:*",
    "@kb-labs/plugin-contracts": "workspace:*",
    "@types/node": "^24.3.3",
    "eslint": "^9",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
