{
  "name": "<%= it.scope ? it.scope + '/' : '' %><%= it.name %>",
  "version": "0.1.0",
  "private": true,
  "description": "<%= it.vars.description %>",
  "license": "<%= it.vars.license %>",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test"
  }
}
