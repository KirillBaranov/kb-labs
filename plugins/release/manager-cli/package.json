{
  "name": "@kb-labs/release-manager-cli",
  "description": "KB Labs Release Manager - CLI commands for release management",
  "version": "2.59.0",
  "type": "module",
  "author": {
    "name": "Kirill Baranov",
    "url": "https://github.com/kirill-baranov"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && pnpm build:studio",
    "build:studio": "rspack build --config rspack.studio.config.mjs",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "dev:studio": "rspack build --config rspack.studio.config.mjs --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests -c ../../vitest.config.ts",
    "test:watch": "vitest -c ../../vitest.config.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@kb-labs/release-manager-changelog": "workspace:*",
    "@kb-labs/release-manager-checks": "workspace:*",
    "@kb-labs/release-manager-contracts": "workspace:*",
    "@kb-labs/release-manager-core": "workspace:*",
    "@kb-labs/sdk": "workspace:*",
    "@kb-labs/studio-plugin-tools": "workspace:*",
    "glob": "^11.0.0",
    "globby": "^11.0.0",
    "npm-packlist": "^10.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@kb-labs/devkit": "workspace:*",
    "@rspack/cli": "latest",
    "@rspack/core": "latest",
    "@types/node": "^24.3.3",
    "@types/npm-packlist": "^7.0.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "kb": {
    "manifest": "./dist/manifest.js"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-router-dom": ">=6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kirill-baranov/kb-labs-release-manager.git",
    "directory": "packages/release-cli"
  },
  "sideEffects": false
}
