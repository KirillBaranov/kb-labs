{
  "name": "@kb-labs/commit-entry",
  "description": "CLI commands and manifest for KB Labs Commit plugin - AI-powered commit generation.",
  "version": "2.76.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin-manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./cli": "./dist/cli/index.js",
    "./lifecycle": "./dist/lifecycle/index.js",
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && pnpm run build:studio",
    "build:cli": "tsup --config tsup.config.ts",
    "build:studio": "rspack build --config rspack.studio.config.mjs",
    "clean": "rimraf dist",
    "dev": "tsup --config tsup.config.ts --watch",
    "dev:studio": "rspack serve --config rspack.studio.config.mjs",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint . --fix",
    "pretype-check": "pnpm --filter @kb-labs/commit-entry build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@kb-labs/commit-contracts": "workspace:*",
    "@kb-labs/commit-core": "workspace:*",
    "@kb-labs/sdk": "workspace:*",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@kb-labs/devkit": "workspace:*",
    "@kb-labs/studio-plugin-tools": "workspace:*",
    "@rspack/cli": "^1.7.0",
    "@rspack/core": "^1.7.0",
    "@types/node": "^24.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "kb": {
    "manifest": "./dist/manifest.js"
  },
  "peerDependencies": {
    "@ant-design/icons": "^5.4.0",
    "@tanstack/react-query": "^5.0.0",
    "antd": "^5.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "antd": {
      "optional": true
    },
    "@ant-design/icons": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "react-router-dom": {
      "optional": true
    }
  },
  "sideEffects": false
}
