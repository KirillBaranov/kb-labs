{
  "name": "@kb-labs/gateway-runtime-server",
  "version": "0.5.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kb-runtime-server": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run -c ../../vitest.config.ts",
    "test:watch": "vitest -c ../../vitest.config.ts",
    "build:docker": "DOCKER_BUILD=1 tsup",
    "docker:build": "pnpm run build:docker && docker build -t kb-runtime-server:local ."
  },
  "dependencies": {
    "@kb-labs/host-agent-core": "workspace:*",
    "@kb-labs/host-agent-contracts": "workspace:*",
    "@kb-labs/plugin-runtime": "workspace:*",
    "@kb-labs/plugin-contracts": "workspace:*"
  },
  "devDependencies": {
    "@kb-labs/devkit": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "vitest": "^3.2.4"
  }
}
