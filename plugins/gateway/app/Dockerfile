FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat

# ── deps ─────────────────────────────────────────────────────────────────────
FROM base AS deps
WORKDIR /app

# Bundle generated by: kb-devkit bundle @kb-labs/gateway-app --docker
# json/ contains only package.json files — optimizes this install layer
COPY .kb/bundle/gateway-app/json/ .

RUN corepack enable pnpm && pnpm install --frozen-lockfile

# ── builder ───────────────────────────────────────────────────────────────────
FROM base AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules

# full/ contains sources of all packages in the closure (prod deps only)
COPY .kb/bundle/gateway-app/full/ .

# Install @kb-labs/devkit from npm — needed for tsup build configs, not in prod closure
RUN corepack enable pnpm && pnpm add -w @kb-labs/devkit

# Build gateway-app and all its workspace deps in topological order
RUN pnpm --filter @kb-labs/gateway-app... run build

# ── runner ───────────────────────────────────────────────────────────────────
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production

RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid 1001 kb

# Copy only gateway-app's prod node_modules + built dist
COPY --from=builder --chown=kb:nodejs /app/plugins/gateway/app/dist ./dist
COPY --from=builder --chown=kb:nodejs /app/plugins/gateway/app/node_modules ./node_modules

# Prod config: adapters + gateway upstreams
COPY plugins/gateway/app/.kb/kb.config.prod.json .kb/kb.config.json

# Marketplace lock with node_modules-relative adapter paths
COPY plugins/gateway/app/.kb/marketplace.prod.lock .kb/marketplace.lock

RUN mkdir -p .kb/database .kb/storage && chown -R kb:nodejs .kb

USER kb

EXPOSE 4000

CMD ["node", "dist/index.js"]
