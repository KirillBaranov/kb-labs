{
  "name": "@kb-labs/infra-worker-core",
  "description": "Infra worker plugin core for workspace/environment/snapshot lifecycle operations.",
  "version": "2.64.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin-manifest": {
      "types": "./dist/manifest.v3.d.ts",
      "import": "./dist/manifest.v3.js"
    },
    "./cli": "./dist/cli/index.js",
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rimraf dist",
    "dev": "tsup --config tsup.config.ts --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint . --fix",
    "pretype-check": "pnpm --filter @kb-labs/infra-worker-core build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@kb-labs/infra-worker-contracts": "workspace:*",
    "@kb-labs/plugin-contracts": "workspace:*",
    "@kb-labs/sdk": "workspace:*",
    "react": "^19.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@kb-labs/devkit": "workspace:*",
    "@kb-labs/plugin-runtime": "workspace:*",
    "@types/node": "^24.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "kb": {
    "manifest": "./dist/manifest.v3.js"
  },
  "sideEffects": false
}
