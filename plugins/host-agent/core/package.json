{
  "name": "@kb-labs/host-agent-core",
  "version": "0.3.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run -c ../../vitest.config.ts",
    "test:watch": "vitest -c ../../vitest.config.ts"
  },
  "dependencies": {
    "@kb-labs/gateway-contracts": "workspace:*",
    "@kb-labs/host-agent-contracts": "workspace:*",
    "@kb-labs/host-agent-transport": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@kb-labs/devkit": "workspace:*",
    "@types/ws": "^8.5.13",
    "rimraf": "^6",
    "tsup": "^8.5.0",
    "vitest": "^3.2.4"
  }
}
