{
  "name": "@kb-labs/marketplace-api",
  "version": "0.1.4",
  "description": "Fastify routes for KB Labs marketplace service",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests -c ../../vitest.config.ts"
  },
  "dependencies": {
    "@kb-labs/core-contracts": "workspace:*",
    "@kb-labs/core-discovery": "workspace:*",
    "@kb-labs/core-platform": "workspace:*",
    "@kb-labs/marketplace-contracts": "workspace:*",
    "@kb-labs/marketplace-core": "workspace:*",
    "@kb-labs/shared-http": "workspace:*",
    "fastify": "^5.3.3",
    "@fastify/swagger": ">=9.5.1",
    "@fastify/swagger-ui": "^5.2.0",
    "fastify-type-provider-zod": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^3.2.4",
    "@kb-labs/devkit": "workspace:*",
    "@types/node": "^24.3.3"
  }
}
