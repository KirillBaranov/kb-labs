{
  "dependencies": {
    "@kb-labs/sdk": "workspace:*"
  },
  "description": "Marketplace CLI plugin — commands for managing plugins, adapters, and other marketplace entities",
  "devDependencies": {
    "@kb-labs/devkit": "workspace:*",
    "@types/node": "^24.3.3",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin-manifest": {
      "import": "./dist/manifest.js"
    }
  },
  "files": [
    "dist"
  ],
  "kb": {
    "manifest": "./dist/manifest.js"
  },
  "main": "./dist/index.js",
  "name": "@kb-labs/marketplace-cli",
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests -c ../../vitest.config.ts",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "2.9.0"
}
