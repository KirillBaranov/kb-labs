{
  "name": "@kb-labs/marketplace-npm",
  "description": "npm/pnpm package source for KB Labs marketplace",
  "version": "2.54.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests -c ../../vitest.config.ts",
    "test:watch": "vitest -c ../../vitest.config.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@kb-labs/marketplace-contracts": "workspace:*",
    "execa": "^9.5.3"
  },
  "devDependencies": {
    "@kb-labs/devkit": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "sideEffects": false
}
