NODE_ENV=development

# OpenAI API Key for Mind RAG embeddings
OPENAI_API_KEY=sk-proj-...

# Qdrant configuration (optional, defaults to localhost:6333)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-key-if-needed

# npm token for publishing
NPM_TOKEN=npm_...

# KB Labs sandbox settings
KB_SANDBOX_MODE=compat
KB_SANDBOX_TRACE=0

# Gateway secrets (used by gateway-app + container execution mode)
GATEWAY_INTERNAL_SECRET=dev-internal-secret-kb-labs
GATEWAY_JWT_SECRET=dev-jwt-secret-kb-labs

# SSH deployment settings (used by kb-deploy and kb-monitor)
SSH_HOST=your.server.ip
SSH_USER=deploy
# Path to your SSH private key file — key must NOT live inside the repo.
# Generate with: ssh-keygen -t ed25519 -f ~/.ssh/kb_deploy -C "deploy@kb-labs"
SSH_KEY_PATH=~/.ssh/kb_deploy
