# ───────────────
# Node & Package managers
# ───────────────
node_modules/
.pnpm-store/
.pnp.*
.pnp.js
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ───────────────
# Build artifacts
# ───────────────
dist/
build/
.cache/
.temp/
tmp/
*.tsbuildinfo
*.tgz

# ───────────────
# Testing
# ───────────────
coverage/
coverage.out
.vitest/
.vscode-test/
.test-analytics/

# ───────────────
# Tool caches
# ───────────────
.wrangler/

# ───────────────
# IDE & OS junk
# ───────────────
.idea/
.vscode/
*.swp
*.swo
*.DS_Store
Thumbs.db

# ───────────────
# Environment & configs
# ───────────────
.env
.env.*.local
.env.local
*.local

# ───────────────
# Private / local-only
# ───────────────
_private/
.worktrees/

# ───────────────
# Next.js build artifacts
# ───────────────
.next/

# ───────────────
# KB Labs runtime data
# ───────────────
.kb/cache/
.kb/logs/
.kb/tmp/
.kb/mind/
.kb/devkit/
.kb/verdaccio/
.kb/bundle/
.kb/release/history/
.kb/release/backup.json

# ───────────────
# Deploy runtime data (docker volumes, db state)
# ───────────────
deploy/docker/

# ───────────────
# custom
# ───────────────
*.sqlite
*.sqlite-wal
*.sqlite-shm
*.db
.kb/analytics/
.kb/database/
.kb/commit/
# Agent/memory session state (runtime, not source)
.kb/agents/sessions/
.kb/memory/sessions/

# kb-labs-ignore
.env
.kb/analytics/
.kb/cache/
.kb/storage/
.kb/tmp/
.kb/logs/
# installer-managed — use .kb/devservices.dev.yaml for local dev
.kb/devservices.yaml
# installer-managed — use .kb/kb.config.json for local dev
.kb/kb.config.jsonc
# end-kb-labs-ignore

# E2E — packed tarballs (generated by pack-all.sh, baked into Docker image)
e2e/packages/*.tgz

# E2E — Playwright report output (generated by test runs)
e2e/tests/report/

# Claude Code — local settings and session state (per-developer)
.claude/

# KB Labs runtime workflows (created by kb-dev start, per-developer)
.kb/workflows/

# Nested .kb/ runtime dirs inside packages (created during local dev)
plugins/**/.kb/
tools/**/.kb/
**/.npmrc
