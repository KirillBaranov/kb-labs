{
  "name": "@kb-labs/studio-federation",
  "description": "Studio Module Federation host logic — page loader, container, error boundary",
  "version": "2.75.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@kb-labs/plugin-contracts": "workspace:*",
    "@kb-labs/studio-devtools": "workspace:*",
    "@kb-labs/studio-event-bus": "workspace:*",
    "@kb-labs/studio-hooks": "workspace:*",
    "@module-federation/runtime": "^2.3.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.0.0",
    "@kb-labs/devkit": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "antd": "^5.21.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "peerDependencies": {
    "@ant-design/icons": "^5.0.0",
    "antd": "^5.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "sideEffects": false
}
