{
  "version": "3.0.0",
  "registryUrl": "https://registry.npmjs.org",
  "core": [
    { "name": "@kb-labs/cli-bin",          "localPath": "/Users/you/kb-labs-workspace/platform/kb-labs-cli/packages/cli-bin" },
    { "name": "@kb-labs/sdk",              "localPath": "/Users/you/kb-labs-workspace/platform/kb-labs-sdk/packages/sdk" },
    { "name": "@kb-labs/core-runtime",     "localPath": "/Users/you/kb-labs-workspace/platform/kb-labs-core/packages/core-runtime" },
    { "name": "@kb-labs/core-contracts",   "localPath": "/Users/you/kb-labs-workspace/platform/kb-labs-core/packages/core-contracts" },
    { "name": "@kb-labs/shared-cli-ui",    "localPath": "/Users/you/kb-labs-workspace/platform/kb-labs-shared/packages/shared-cli-ui" },
    { "name": "@kb-labs/core-state-daemon","localPath": "/Users/you/kb-labs-workspace/platform/kb-labs-core/packages/core-state-daemon" }
  ],
  "services": [
    { "id": "rest",        "pkg": "@kb-labs/rest-api-app",    "description": "REST API (port 5050)",          "default": true, "localPath": "/Users/you/kb-labs-workspace/platform/kb-labs-rest-api/apps/rest-api" },
    { "id": "workflow",    "pkg": "@kb-labs/workflow-daemon",  "description": "Workflow engine (port 7778)",   "default": true, "localPath": "/Users/you/kb-labs-workspace/platform/kb-labs-workflow/packages/workflow-daemon" },
    { "id": "gateway",     "pkg": "@kb-labs/gateway-app",     "description": "Central router (port 4000)",    "default": true, "localPath": "/Users/you/kb-labs-workspace/infra/kb-labs-gateway/apps/gateway-app" },
    { "id": "marketplace", "pkg": "@kb-labs/marketplace-app", "description": "Marketplace (port 5070)",       "default": true, "localPath": "/Users/you/kb-labs-workspace/platform/kb-labs-marketplace/apps/marketplace" },
    { "id": "studio",      "pkg": "@kb-labs/studio",          "description": "Web UI (port 3000)",            "default": true, "localPath": "/Users/you/kb-labs-workspace/platform/kb-labs-studio/apps/studio" }
  ],
  "plugins": [
    { "id": "marketplace", "pkg": "@kb-labs/marketplace-cli", "description": "Install, list, enable plugins", "default": true, "localPath": "/Users/you/kb-labs-workspace/platform/kb-labs-marketplace/packages/marketplace-cli" },
    { "id": "mind",        "pkg": "@kb-labs/mind-cli",        "description": "AI code search (RAG)",           "default": true, "localPath": "/Users/you/kb-labs-workspace/plugins/kb-labs-mind/packages/mind-cli" },
    { "id": "agents",      "pkg": "@kb-labs/agent-cli",       "description": "Autonomous agents",              "default": true, "localPath": "/Users/you/kb-labs-workspace/plugins/kb-labs-agents/packages/agent-cli" },
    { "id": "ai-review",   "pkg": "@kb-labs/review-cli",      "description": "AI code review",                 "default": true, "localPath": "/Users/you/kb-labs-workspace/plugins/kb-labs-ai-review/packages/review-cli" },
    { "id": "commit",      "pkg": "@kb-labs/commit-cli",      "description": "AI commit generation",           "default": true, "localPath": "/Users/you/kb-labs-workspace/plugins/kb-labs-commit-plugin/packages/commit-cli" }
  ],
  "binaries": [
    { "id": "kb-dev", "name": "kb-dev", "description": "Service manager", "localPath": "/Users/you/kb-labs-workspace/infra/kb-labs-dev/kb-dev" }
