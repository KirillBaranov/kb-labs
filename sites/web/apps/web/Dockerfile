FROM node:20-alpine AS base

# ── deps ────────────────────────────────────────────────────────────────────
FROM base AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Bundle generated by: kb-devkit bundle @kb-labs/web-site --docker
# json/ contains only package.json files — optimizes this install layer
COPY .kb/bundle/web-site/json/ .

RUN corepack enable pnpm && pnpm install --frozen-lockfile --filter @kb-labs/web-site...

# ── builder ─────────────────────────────────────────────────────────────────
FROM base AS builder
WORKDIR /app

COPY --from=deps /app/node_modules                                    ./node_modules
COPY --from=deps /app/sites/web/apps/web/node_modules                 ./sites/web/apps/web/node_modules
COPY --from=deps /app/sites/web/packages/i18n/node_modules            ./sites/web/packages/i18n/node_modules
COPY --from=deps /app/sites/web/packages/og/node_modules              ./sites/web/packages/og/node_modules
COPY --from=deps /app/sites/web/packages/web-data-source/node_modules ./sites/web/packages/web-data-source/node_modules

# full/ contains sources of all packages in the closure
COPY .kb/bundle/web-site/full/ .

ENV NEXT_TELEMETRY_DISABLED=1
RUN corepack enable pnpm && pnpm --filter @kb-labs/web-site run build

# ── runner ──────────────────────────────────────────────────────────────────
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid 1001 nextjs

COPY --from=builder /app/sites/web/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/sites/web/apps/web/.next/static ./sites/web/apps/web/.next/static

USER nextjs

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["node", "sites/web/apps/web/server.js"]
